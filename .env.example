# OpenClaw Opik Plugin
# Copy to .env and set values for local development/tests.

# Opik API endpoint
# For Opik Cloud:
OPIK_URL_OVERRIDE="https://www.comet.com/opik/api"
# For self-hosted/local Opik, use something like:
# OPIK_URL_OVERRIDE="http://localhost:5173/api"

# Authentication (optional for unauthenticated local deployments)
OPIK_API_KEY="your-api-key-here"

# Trace destination
OPIK_PROJECT_NAME="openclaw"
OPIK_WORKSPACE="default"
